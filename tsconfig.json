{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@codeterm/plugin-sdk": ["node_modules/@codeterm/plugin-sdk/src/index.ts"]
    },
    "types": []
  },
  "include": ["*/src/**/*.ts", "*/src/**/*.tsx", "*/ui/src/**/*.ts", "*/ui/src/**/*.tsx"]
}
